# ffufai-zai configuration
# Copy file ini menjadi .env: cp .env.example .env
# Lalu isi API key kamu di bawah ini

# === Z.ai (Direkomendasikan untuk pengguna Indonesia) ===
# Dapatkan API key di: https://z.ai/manage-apikey/apikey-list
# Atau beli via: https://apikuy.my.id/
ANTHROPIC_AUTH_TOKEN=your-zai-api-key-here
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic

# === Anthropic (Claude) ===
# Hapus komentar (#) pada baris di bawah dan isi API key kamu
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# === OpenAI (GPT) ===
# Hapus komentar (#) pada baris di bawah dan isi API key kamu
# OPENAI_API_KEY=sk-xxxxx

# === Opsional ===
# Model yang digunakan (default: claude-sonnet-4)
# ZAI_MODEL=claude-sonnet-4
